<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit <%= data.name %></title>
    <link rel="stylesheet" href="/edit.css">
</head>
<body>
    <div class="container">
        <h1>Edit Animal</h1>

        <form method="POST" action="/home/<%= type %>/<%= data.id %>?_method=PATCH" enctype="multipart/form-data">

            <label for="name">Common Name</label>
            <input type="text" name="name" id="name" value="<%= data.name %>">

            <label for="span">Lifespan</label>
            <input type="text" name="lifespan" id="span" value="<%= data.lifespan %>">

            <label for="size">Size</label>
            <input type="text" name="size" id="size" value="<%= data.size %>">

            <label for="scientific_name">Scientific Name</label>
            <input type="text" name="scientific_name" id="scientific_name" value="<%= data.scientific_name %>">

            <label for="image">Image</label>
            <input type="file" name="image_url" id="image">

            <label for="description">Description</label>
            <textarea name="description" id="description"><%= data.description %></textarea>

            <button type="submit">Update Animal</button>
        </form>
    </div>
</body>
</html>
